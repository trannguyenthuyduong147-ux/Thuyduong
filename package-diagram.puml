@startuml
title ATM System Package Diagram

package "UI" {
    class ATMInterface
    class DisplayScreen
    class Keypad
    class CardReader
    class ReceiptPrinter
}

package "Controller" {
    class ATMController
    class TransactionController
    class AuthenticationController
    class SessionManager
}

package "BankService" {
    class BankService
    class AccountService
    class TransactionService
    class ValidationService
}

package "Hardware" {
    class CashDispenser
    class DepositSlot
    class CardReaderHW
    class NetworkInterface
}

package "Model" {
    class ATM
    class Card
    class Account
    class Transaction
    class Customer
    class Bank
}

' Package dependencies
UI ..> Controller : uses
Controller ..> BankService : calls
Controller ..> Hardware : controls
BankService ..> Model : manipulates
Hardware ..> Model : updates

' More detailed dependencies
ATMInterface --> ATMController
TransactionController --> BankService
AuthenticationController --> ValidationService
CashDispenser --> ATM
BankService --> Bank

@enduml
